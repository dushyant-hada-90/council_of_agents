# Google Cloud — STT, Gemini (Vertex), TTS
GCP_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=

# Gemini models
GEMINI_PLANNER_MODEL=gemini-2.0-flash
GEMINI_CHAT_MODEL=gemini-2.0-flash
GEMINI_ROUTING_MODEL=gemini-2.0-flash
GEMINI_ROUTING_TIMEOUT_MS=3000
GEMINI_MERGED_TURN_TIMEOUT_MS=12000

# AWS S3 — meeting audio chunk storage
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=

# Guest audio limits (seconds of spoken audio)
GUEST_AUDIO_WARN_SECONDS=480
GUEST_AUDIO_MAX_SECONDS=600

# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=minimal
HUMAN_STT_TIMEOUT_MS=10000
TRANSCRIPT_FLUSH_INTERVAL_MS=60000
MEETING_IDLE_TIMEOUT_MS=240000
SESSION_RECORDINGS_DIR=

# Auth — long random string (e.g. openssl rand -base64 32)
AUTH_SECRET=

# Supabase Postgres (database only — not Supabase Auth)
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
