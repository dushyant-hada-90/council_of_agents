# OpenAI (required)
OPENAI_API_KEY=
OPENAI_REALTIME_MODEL=gpt-realtime-2
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe

# Groq (optional — turn routing + STT fallback)
GROQ_API_KEY=
GROQ_ROUTING_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_ROUTING_TIMEOUT_MS=3000

# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=minimal
HUMAN_REALTIME_TRANSCRIPT_TIMEOUT_MS=5000
TRANSCRIPT_FLUSH_INTERVAL_MS=60000
SESSION_RECORDINGS_DIR=

# Auth (required — use a long random string, e.g. openssl rand -base64 32)
AUTH_SECRET=

# Supabase Postgres (required — Auth is NOT used; only database storage)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
