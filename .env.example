# Google Cloud — TTS (service account); Gemini (Vertex publisher API key)
GCP_PROJECT_ID=
GOOGLE_API_KEY=
GOOGLE_APPLICATION_CREDENTIALS=

# Sarvam — human speech-to-text
SARVAM_API_KEY=
SARVAM_STT_MODEL=saarika:v2.5
SARVAM_STT_LANGUAGE_CODE=unknown

# Gemini models (Vertex publisher endpoint)
GEMINI_PLANNER_MODEL=gemini-3.5-flash
GEMINI_CHAT_MODEL=gemini-3.5-flash
GEMINI_MERGED_TURN_TIMEOUT_MS=12000
# Opt-in Google Search grounding on Vertex Gemini (adds tools.googleSearch to generateContent)
GEMINI_GOOGLE_SEARCH_GROUNDING=false
# Comma-separated ops: structured_json (guest planner), merged_turn (live agent replies)
GEMINI_GOOGLE_SEARCH_OPERATIONS=structured_json,merged_turn

# AWS S3 — meeting audio chunk storage
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=

# Guest audio limits (seconds of spoken audio)
GUEST_AUDIO_WARN_SECONDS=480
GUEST_AUDIO_MAX_SECONDS=600

# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=minimal
HUMAN_STT_TIMEOUT_MS=10000
HUMAN_STT_SEGMENT_SEC=30
HUMAN_STT_OVERLAP_SEC=5
POST_TRANSCRIPT_SILENCE_MS=200
GUEST_MIN_AGENTS=4
TRANSCRIPT_FLUSH_INTERVAL_MS=60000
MEETING_IDLE_TIMEOUT_MS=240000
# Max agent turns before inviting the human back (2, 4, or 6)
MAX_AI_TURNS_BEFORE_HUMAN=4
SESSION_RECORDINGS_DIR=

# Auth — long random string (e.g. openssl rand -base64 32)
AUTH_SECRET=

# Supabase Postgres (database only — not Supabase Auth)
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
