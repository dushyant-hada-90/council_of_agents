{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "noEmit": false,
    "outDir": "./dist",
    "rootDir": ".",
    "jsx": "react-jsx",
    "incremental": false,
    "plugins": []
  },
  "include": [
    "server.ts",
    "server/**/*",
    "lib/env.ts",
    "lib/config/**/*",
    "lib/auth/**/*",
    "lib/agents/**/*",
    "lib/supabase/**/*",
    "lib/s3/**/*",
    "lib/pipeline/**/*",
    "lib/logger/**/*",
    "lib/helpers/**/*"
  ],
  "exclude": ["node_modules", "app", "components", "middleware.ts"]
}
